# ==============================================================================
# InboxHire CRM Environment Variables Configuration
# ==============================================================================
# Copy this file to '.env' (for local environment) or '.env.local' and fill in values.
# If these variables are not set, the app runs in Demo Mode using realistic mock data.

# 1. DATABASE CONFIGURATION (Required for Live CRM Data)
# Prisma supports PostgreSQL. Generate a free database at Neon (https://neon.tech) or Supabase (https://supabase.com)
DATABASE_URL="postgresql://username:password@ep-cool-name.us-east-2.aws.neon.tech/inboxhire?sslmode=require"

# 2. SESSION SECURITY
# Provide any long random string to sign auth session cookies
JWT_SECRET="generate-some-random-32-character-secret-key-string-here"

# 3. GOOGLE OAUTH CREDENTIALS (Required to Sync real Gmail)
# Go to the Google Cloud Console (https://console.cloud.google.com)
# Create a new project, enable the "Gmail API", and create OAuth 2.0 Credentials.
# Authorized Redirect URI: http://localhost:3000/api/auth/callback
GOOGLE_CLIENT_ID="your-google-client-id-here.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-your-google-client-secret-here"

# (Optional) Override Redirect URI. 
# Defaults to http://localhost:3000/api/auth/callback on localhost, or matches your deployment domain automatically.
# GOOGLE_REDIRECT_URI="https://inboxhire.vercel.app/api/auth/callback"

# 4. GEMINI AI CLASSIFIER (Optional, highly recommended)
# Get a free API Key from Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY="your-gemini-api-key-here"

