datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  accessToken  String?       // Stored OAuth token
  refreshToken String?       // To refresh access
  createdAt    DateTime      @default(now())
  applications Application[]
}

model Application {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName  String
  contactName  String?
  contactEmail String?
  status       String   // "Applied" | "Replied" | "Interview" | "Rejected" | "Follow Up Required"
  sentDate     DateTime
  lastActivity DateTime
  threads      Thread[]
  createdAt    DateTime @default(now())
}

model Thread {
  id              String      @id @default(uuid())
  applicationId   String
  application     Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  gmailThreadId   String      @unique
  subject         String
  lastMessageDate DateTime
}
